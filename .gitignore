.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
.vite/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
*.lcov
.nyc_output

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V3
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# TypeScript
*.tsbuildinfo

# PostgreSQL backups
*.sql.bak
*.dump

# Uploads temporales
uploads/temp/
